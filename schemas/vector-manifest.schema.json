{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/NagareWorks/nnrp-conformance/schemas/vector-manifest.schema.json",
  "title": "NNRP Vector Manifest",
  "type": "object",
  "required": ["protocol_version", "vectors"],
  "properties": {
    "$schema": {"type": "string"},
    "protocol_version": {"type": "string", "minLength": 1},
    "generator": {"type": "string"},
    "generated_from": {"type": "string"},
    "vectors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "kind", "hex", "bytes", "description"],
        "properties": {
          "name": {"type": "string", "minLength": 1},
          "kind": {"type": "string", "minLength": 1},
          "hex": {"type": "string", "minLength": 2},
          "bytes": {"type": "integer", "minimum": 0},
          "description": {"type": "string"}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}