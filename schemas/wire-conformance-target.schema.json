{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/NagareWorks/nnrp-conformance/schemas/wire-conformance-target.schema.json",
  "title": "NNRP Wire-level Conformance Target Manifest",
  "type": "object",
  "$defs": {
    "transportSecurity": {
      "type": "object",
      "required": [
        "server_name",
        "trusted_certificate_der_path",
        "certificate_der_path",
        "private_key_pkcs8_der_path"
      ],
      "properties": {
        "server_name": {"type": "string", "minLength": 1},
        "trusted_certificate_der_path": {"type": "string", "minLength": 1},
        "certificate_der_path": {"type": "string", "minLength": 1},
        "private_key_pkcs8_der_path": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    }
  },
  "required": ["target_name", "protocol_version", "suite_version", "wire_conformance"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "target_name": {
      "type": "string",
      "minLength": 1
    },
    "protocol_version": {
      "type": "string",
      "const": "nnrp-1-preview4"
    },
    "suite_version": {
      "type": "string",
      "minLength": 1
    },
    "wire_conformance": {
      "type": "object",
      "required": ["modes", "transports", "capabilities", "limits"],
      "properties": {
        "modes": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["suite_as_client", "suite_as_server", "suite_as_proxy"]
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "transports": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "endpoint", "tls"],
            "properties": {
              "name": {
                "type": "string",
                "enum": ["tcp", "quic", "websocket", "ipc"]
              },
              "endpoint": {
                "type": "string",
                "minLength": 1
              },
              "tls": {
                "type": "boolean"
              },
              "security": {
                "$ref": "#/$defs/transportSecurity"
              }
            },
            "allOf": [
              {
                "if": {
                  "properties": {"tls": {"const": true}},
                  "required": ["tls"]
                },
                "then": {"required": ["security"]},
                "else": {"not": {"required": ["security"]}}
              },
              {
                "if": {
                  "properties": {"name": {"const": "quic"}},
                  "required": ["name"]
                },
                "then": {"properties": {"tls": {"const": true}}}
              },
              {
                "if": {
                  "properties": {"name": {"enum": ["tcp", "ipc"]}},
                  "required": ["name"]
                },
                "then": {"properties": {"tls": {"const": false}}}
              },
              {
                "if": {
                  "properties": {"name": {"const": "websocket"}},
                  "required": ["name"]
                },
                "then": {
                  "properties": {"endpoint": {"pattern": "^wss?://"}},
                  "allOf": [
                    {
                      "if": {
                        "properties": {"endpoint": {"pattern": "^wss://"}},
                        "required": ["endpoint"]
                      },
                      "then": {"properties": {"tls": {"const": true}}},
                      "else": {"properties": {"tls": {"const": false}}}
                    }
                  ]
                }
              }
            ],
            "additionalProperties": false
          },
          "minItems": 1
        },
        "capabilities": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "limits": {
          "type": "object",
          "required": ["max_frame_bytes", "max_in_flight"],
          "properties": {
            "max_frame_bytes": {
              "type": "integer",
              "minimum": 1
            },
            "max_in_flight": {
              "type": "integer",
              "minimum": 1
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
