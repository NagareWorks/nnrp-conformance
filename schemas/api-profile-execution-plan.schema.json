{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/NagareWorks/nnrp-conformance/schemas/api-profile-execution-plan.schema.json",
  "title": "NNRP API Profile Execution Plan",
  "type": "object",
  "required": [
    "profile",
    "schema_version",
    "adapter",
    "artifacts",
    "coverage_matrix",
    "cases"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "profile": {
      "type": "string",
      "const": "openai-compatible"
    },
    "schema_version": {
      "type": "string",
      "const": "openai-compatible/1"
    },
    "adapter": {
      "type": "string",
      "minLength": 1
    },
    "artifacts": {
      "type": "object",
      "required": [
        "results_path",
        "evidence_dir"
      ],
      "properties": {
        "results_path": {
          "type": "string"
        },
        "evidence_dir": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "coverage_matrix": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "feature",
          "required_capabilities",
          "summary",
          "statuses",
          "case_ids"
        ],
        "properties": {
          "feature": {
            "type": "string",
            "minLength": 1
          },
          "required_capabilities": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "summary": {
            "$ref": "#/$defs/summary"
          },
          "statuses": {
            "$ref": "#/$defs/statuses"
          },
          "case_ids": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          }
        },
        "additionalProperties": false
      }
    },
    "cases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "operation",
          "status",
          "request",
          "expect"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "operation": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "mandatory",
              "optional",
              "experimental",
              "deprecated"
            ]
          },
          "required_capabilities": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "request": {
            "type": "object"
          },
          "expect": {
            "type": "object"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "$defs": {
    "summary": {
      "type": "object",
      "required": [
        "selected_cases",
        "not_claimed_cases",
        "informational_cases"
      ],
      "properties": {
        "selected_cases": {
          "type": "integer",
          "minimum": 0
        },
        "not_claimed_cases": {
          "type": "integer",
          "minimum": 0
        },
        "informational_cases": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "statuses": {
      "type": "object",
      "required": [
        "mandatory_cases",
        "optional_cases",
        "experimental_cases",
        "deprecated_cases"
      ],
      "properties": {
        "mandatory_cases": {
          "type": "integer",
          "minimum": 0
        },
        "optional_cases": {
          "type": "integer",
          "minimum": 0
        },
        "experimental_cases": {
          "type": "integer",
          "minimum": 0
        },
        "deprecated_cases": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
