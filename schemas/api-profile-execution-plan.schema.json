{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/NagareWorks/nnrp-conformance/schemas/api-profile-execution-plan.schema.json",
  "title": "NNRP API Profile Execution Plan",
  "type": "object",
  "required": [
    "profile",
    "schema_version",
    "adapter",
    "artifacts",
    "cases"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "profile": {
      "type": "string",
      "const": "openai-compatible"
    },
    "schema_version": {
      "type": "string",
      "const": "openai-compatible/1"
    },
    "adapter": {
      "type": "string",
      "minLength": 1
    },
    "artifacts": {
      "type": "object",
      "required": [
        "results_path",
        "evidence_dir"
      ],
      "properties": {
        "results_path": {
          "type": "string"
        },
        "evidence_dir": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "cases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "operation",
          "status",
          "request",
          "expect"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "operation": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "mandatory",
              "optional",
              "experimental",
              "deprecated"
            ]
          },
          "required_capabilities": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "request": {
            "type": "object"
          },
          "expect": {
            "type": "object"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
