{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/NagareWorks/nnrp-conformance/schemas/semantic-vector-recipes.schema.json",
  "title": "NNRP Semantic Vector Recipes",
  "type": "object",
  "$defs": {
    "unsignedDecimalU64": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]{0,19})$"
    }
  },
  "required": ["protocol_version", "vectors"],
  "properties": {
    "$schema": {"type": "string"},
    "protocol_version": {"type": "string", "minLength": 1},
    "vectors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["recipe_type", "name", "description"],
        "properties": {
          "recipe_type": {"type": "string", "minLength": 1},
          "name": {"type": "string", "minLength": 1},
          "description": {"type": "string"}
        },
        "allOf": [
          {
            "if": {
              "properties": {
                "recipe_type": {
                  "enum": [
                    "object_reference_block_v4",
                    "cache_put_metadata_v4",
                    "cache_ack_metadata_v4",
                    "cache_invalidate_metadata_v4",
                    "cache_reference_metadata_v4",
                    "cache_miss_metadata_v4"
                  ]
                }
              },
              "required": ["recipe_type"]
            },
            "then": {
              "required": ["cache_namespace", "cache_key_hi", "cache_key_lo"],
              "properties": {
                "cache_namespace": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 4294967295
                },
                "cache_key_hi": {"$ref": "#/$defs/unsignedDecimalU64"},
                "cache_key_lo": {"$ref": "#/$defs/unsignedDecimalU64"}
              }
            }
          },
          {
            "if": {
              "properties": {"recipe_type": {"const": "cache_reference_metadata_v4"}},
              "required": ["recipe_type"]
            },
            "then": {
              "required": ["lease_id", "producer_trace_id"],
              "properties": {
                "lease_id": {"$ref": "#/$defs/unsignedDecimalU64"},
                "producer_trace_id": {"$ref": "#/$defs/unsignedDecimalU64"}
              }
            }
          }
        ],
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": false
}
