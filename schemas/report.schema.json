{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/NagareWorks/nnrp-conformance/schemas/report.schema.json",
  "title": "NNRP Conformance Report",
  "type": "object",
  "required": [
    "protocol_version",
    "implementation_name",
    "summary",
    "compatibility_matrix",
    "cases"
  ],
  "properties": {
    "protocol_version": {
      "type": "string"
    },
    "implementation_name": {
      "type": "string"
    },
    "summary": {
      "type": "object",
      "required": [
        "selected_cases",
        "not_claimed_cases",
        "informational_cases"
      ],
      "properties": {
        "selected_cases": {
          "type": "integer",
          "minimum": 0
        },
        "not_claimed_cases": {
          "type": "integer",
          "minimum": 0
        },
        "informational_cases": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": true
    },
    "compatibility_matrix": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "feature",
          "required_capabilities",
          "summary",
          "statuses",
          "case_ids"
        ],
        "properties": {
          "feature": {
            "type": "string"
          },
          "required_capabilities": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "summary": {
            "type": "object",
            "required": [
              "selected_cases",
              "not_claimed_cases",
              "informational_cases"
            ],
            "properties": {
              "selected_cases": {
                "type": "integer",
                "minimum": 0
              },
              "not_claimed_cases": {
                "type": "integer",
                "minimum": 0
              },
              "informational_cases": {
                "type": "integer",
                "minimum": 0
              }
            },
            "additionalProperties": false
          },
          "statuses": {
            "type": "object",
            "required": [
              "mandatory_cases",
              "optional_cases",
              "experimental_cases",
              "deprecated_cases"
            ],
            "properties": {
              "mandatory_cases": {
                "type": "integer",
                "minimum": 0
              },
              "optional_cases": {
                "type": "integer",
                "minimum": 0
              },
              "experimental_cases": {
                "type": "integer",
                "minimum": 0
              },
              "deprecated_cases": {
                "type": "integer",
                "minimum": 0
              }
            },
            "additionalProperties": false
          },
          "case_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": false
      }
    },
    "cases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "selection"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "selection": {
            "type": "string",
            "enum": [
              "selected",
              "not_claimed",
              "informational"
            ]
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": false
}