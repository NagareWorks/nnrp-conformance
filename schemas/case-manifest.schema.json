{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/NagareWorks/nnrp-conformance/schemas/case-manifest.schema.json",
  "title": "NNRP Case Manifest",
  "type": "object",
  "required": [
    "protocol_version",
    "manifest_name",
    "cases"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "protocol_version": {
      "type": "string",
      "minLength": 1
    },
    "manifest_name": {
      "type": "string",
      "minLength": 1
    },
    "cases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "layer",
          "status",
          "feature",
          "required_capabilities",
          "description"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "layer": {
            "type": "string",
            "enum": [
              "L0",
              "L1",
              "L2",
              "L3",
              "L4"
            ]
          },
          "status": {
            "type": "string",
            "enum": [
              "mandatory",
              "optional",
              "experimental",
              "deprecated"
            ]
          },
          "feature": {
            "type": "string",
            "minLength": 1
          },
          "required_capabilities": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "description": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}