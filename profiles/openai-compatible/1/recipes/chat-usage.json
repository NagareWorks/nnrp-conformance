{
  "$schema": "../../../../schemas/api-profile-recipe.schema.json",
  "id": "openai-compatible.chat.usage",
  "profile": "openai-compatible",
  "schema_version": "openai-compatible/1",
  "operation": "chat.completions.create",
  "required_capabilities": [
    "api.level1",
    "api.chat.completions.create",
    "api.streaming"
  ],
  "status": "mandatory",
  "parameters": {
    "MODEL_ID": "example-model"
  },
  "request": {
    "body": {
      "model": "${MODEL_ID}",
      "messages": [
        {
          "role": "user",
          "content": "Say hello."
        }
      ],
      "stream": true,
      "stream_options": {
        "include_usage": true
      }
    }
  },
  "expect": {
    "events": [
      {
        "type": "response.output_text.delta",
        "optional": true
      },
      {
        "type": "response.usage",
        "min_count": 1
      }
    ],
    "terminal": "success"
  }
}
