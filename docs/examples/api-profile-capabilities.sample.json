{
  "$schema": "../../schemas/api-profile-capabilities.schema.json",
  "adapter": "vllm-nnrp-adapter",
  "profile": "openai-compatible",
  "schema_version": "openai-compatible/1",
  "compatibility_levels": [
    1
  ],
  "operations": [
    {
      "name": "chat.completions.create",
      "streaming": true,
